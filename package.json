{
  "name": "pibarm",
  "version": "0.1.0",
  "private": true,
  "description": "Pi skills and extensions for MCP CLI wrappers, agent orchestration, model presets, planning, execution, and subagents.",
  "keywords": [
    "agent-skills",
    "mcp",
    "pi",
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test tests",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/doctor.mjs --write",
    "audit:prompt": "bun scripts/prompt-audit.ts",
    "eval:agent": "node scripts/eval-agent.mjs",
    "check:pi-latest": "node scripts/check-pi-latest.mjs",
    "list": "find extensions skills prompts -maxdepth 3 -type f | sort"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.81.0",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "packageManager": "bun@1.3.13",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./.pi/themes"
    ]
  }
}
