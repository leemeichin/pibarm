---
/**
 * Status badge. Tones mirror the pibarm TUI statusline colour mapping.
 * variant="term" renders the flat terminal-native form (no chip).
 */
interface Props {
  tone?: "success" | "warning" | "danger" | "info" | "merged" | "accent" | "muted";
  solid?: boolean;
  dot?: boolean;
  variant?: "pill" | "term";
  class?: string;
  [key: string]: unknown;
}

const { tone = "muted", solid = false, dot = false, variant = "pill", class: className = "", ...rest } = Astro.props;

const cls =
  variant === "term"
    ? `pib-badge-term pib-badge-term--${tone} ${className}`.trim()
    : `pib-badge pib-badge--${tone} ${solid ? "pib-badge--solid" : ""} ${className}`.replace(/\s+/g, " ").trim();
---

<span class={cls} {...rest}>
  {dot && <span class="pib-badge__dot"></span>}
  <slot name="leading" />
  <slot />
</span>
