---
/** Documentation admonition. */
interface Props {
  tone?: "note" | "tip" | "warning" | "danger";
  title?: string | null;
  icon?: string | null;
  class?: string;
  [key: string]: unknown;
}

const GLYPH: Record<string, string> = { note: "ℹ", tip: "✓", warning: "▲", danger: "!" };
const { tone = "note", title = null, icon = null, class: className = "", ...rest } = Astro.props;
---

<div class={`pib-callout pib-callout--${tone} ${className}`.trim()} {...rest}>
  <div class="pib-callout__ic" style="font-family:var(--font-mono);font-weight:700;font-size:15px;">
    {icon || GLYPH[tone]}
  </div>
  <div class="pib-callout__body">
    {title && <p class="pib-callout__title">{title}</p>}
    <slot />
  </div>
</div>
