---
/** A slash-command reference row: name + description. */
interface Props {
  name: string;
  args?: string | null;
  class?: string;
  [key: string]: unknown;
}
const { name, args = null, class: className = "", ...rest } = Astro.props;
---

<div class={`pib-cmd ${className}`.trim()} {...rest}>
  <div class="pib-cmd__name">
    <span class="pib-cmd__slash">{name}{args ? " " + args : ""}</span>
    <slot name="trailing" />
  </div>
  <div class="pib-cmd__desc"><slot /></div>
</div>
