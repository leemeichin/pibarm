---
/**
 * The pibarm statusline footer: project / model / context on the left,
 * repo / forge / CI status on the right, with colour-coded PR & CI.
 */
import Icon from "./Icon.astro";

interface Props {
  project?: string;
  model?: string;
  context?: number;
  branch?: string;
  dirty?: number;
  pr?: { num: number; state: string } | null;
  ci?: "pass" | "running" | "fail" | "unknown";
  variant?: "panel" | "bare";
  theme?: "dark" | "light";
  class?: string;
  [key: string]: unknown;
}

const PR_TONE: Record<string, string> = { open: "success", draft: "muted", merged: "merged", closed: "danger" };
const CI_TONE: Record<string, string> = { pass: "success", running: "warning", fail: "danger", unknown: "muted" };

const {
  project = "pibarm",
  model = "anthropic/Sonnet 4.5",
  context = 37,
  branch = "main",
  dirty = 2,
  pr = { num: 12, state: "open" },
  ci = "pass",
  variant = "panel",
  theme = "dark",
  class: className = "",
  ...rest
} = Astro.props;

const prTone = pr ? PR_TONE[pr.state] || "muted" : "muted";
const ciTone = CI_TONE[ci] || "muted";
const bare = variant === "bare" ? "pib-statusline--bare" : "";
const light = theme === "light" ? "pib-statusline--light" : "";
const cls = `pib-statusline ${bare} ${light} ${className}`.replace(/\s+/g, " ").trim();
---

<div class={cls} {...rest}>
  <div class="pib-statusline__grp">
    <span class="pib-statusline__seg pib-statusline__proj">
      <Icon name="sandwich" size={14} /> {project}
    </span>
    <span class="pib-statusline__seg pib-statusline__dim">
      <Icon name="bot" size={14} /> <span class="pib-statusline__val">{model}</span>
    </span>
    <span class="pib-statusline__seg pib-statusline__dim">
      <Icon name="gauge" size={14} /> ctx {context}%
    </span>
  </div>
  <div class="pib-statusline__grp">
    <span class="pib-statusline__seg">
      <Icon name="git-branch" size={14} /> {branch}
      {dirty ? <span class="pib-statusline__dim"> &plusmn;{dirty}</span> : null}
    </span>
    {pr && (
      <span class={`pib-statusline__seg pib-sl--${prTone}`}>
        <Icon name="git-pull-request" size={14} /> #{pr.num}
      </span>
    )}
    <span class={`pib-statusline__seg pib-sl--${ciTone}`}>
      <Icon name="activity" size={14} /> CI
    </span>
  </div>
</div>
