---
import Base from "../layouts/Base.astro";
import { Badge, Button, CodeBlock, Icon, StatusLine } from "pibarm-ds";
import Demos from "../components/Demos.jsx";
import { FEATURES } from "../data/site.ts";

const base = import.meta.env.BASE_URL;
---

<Base active="home">
  <section class="pib-hero">
    <div>
      <span class="hero-eyebrow"><Icon name="sandwich" size={15} /> pi extensions + skills</span>
      <h1 class="hero-h1">pi extensions and skills.<br />Served with gravy.</h1>
      <p class="hero-lead">A pile of bits I bolted onto <b>pi</b>: it plans before it edits, keeps risky work in a worktree, and lets me watch agents work in WezTerm. Mostly for me — install it if you fancy.</p>
      <div class="hero-ctas">
        <Button variant="primary" size="lg" as="a" href={`${base}docs`}>
          <Icon slot="leading" name="terminal" size={16} />
          Read the docs
        </Button>
        <Button variant="ghost" size="lg" as="a" href="#demos">
          <Icon slot="leading" name="play" size={16} />
          Watch it work
        </Button>
      </div>
      <div class="hero-install">
        <CodeBlock language="bash" code="pi install git@github.com:leemeichin/pibarm.git" />
      </div>
    </div>
    <div class="hero-mascot-wrap">
      <img class="hero-mascot" src={`${base}assets/pie-logo.png`} alt="pibarm pie mascot" />
    </div>
  </section>

  <section style="padding:26px 0;">
    <div class="section-head">
      <h2>What's in the barm</h2>
      <span class="note">extensions &amp; skills</span>
    </div>
    <div class="pib-feat-grid">
      {FEATURES.map((f) => (
        <div class="feat-card">
          <span class="feat-icon"><Icon name={f.icon} size={20} /></span>
          <p class="feat-eyebrow">{f.eyebrow}</p>
          <h3 class="feat-title">{f.title}</h3>
          <p class="feat-body">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="demos" class="demo-section" aria-labelledby="demos-title">
    <div class="section-head">
      <h2 id="demos-title">See it work</h2>
      <span class="note">simulations and snapshots · choose a tab</span>
    </div>
    <Demos client:visible />
  </section>

  <section class="pib-band">
    <div>
      <span class="band-eyebrow">The Matrix</span>
      <h2 class="band-h2">Watch your agents work.</h2>
      <p class="band-lead">Spawn scout, planner and worker agents beside the parent Pi in real WezTerm panes. Watch them, capture their logs, and join them.</p>
      <Button variant="primary" as="a" href="#demos">
        <Icon slot="leading" name="layers" size={15} />
        See the demo
      </Button>
    </div>
    <div>
      <StatusLine project="pibarm" model="anthropic/Sonnet 4.5" context={41} branch="fix-flaky" dirty={3} pr={{ num: 128, state: "open" }} ci="running" />
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;">
        <span class="band-prlabel">PR states:</span>
        <Badge tone="success" dot>open</Badge>
        <Badge tone="muted" dot>draft</Badge>
        <Badge tone="merged" dot>merged</Badge>
        <Badge tone="danger" dot>closed</Badge>
      </div>
    </div>
  </section>
</Base>
